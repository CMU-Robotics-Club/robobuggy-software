<launch>
    <arg name="config_file" default="src/buggy/config/nand_ghost_launch_mockroll.yaml"/>

    <node pkg="buggy" exec="controller_node.py" name="SC_controller" output = "screen" namespace="SC">
            <param from="$(var config_file)"/>
    </node>

    <node pkg="buggy" exec="path_planner.py" name="SC_path_planner" namespace="SC" output = "screen">
        <param from="$(var config_file)"/>
    </node>

    <node pkg="topic_tools" exec="relay" name="relay_node" output="screen">
        <param name="input_topic" value="/NAND/self/state"/>
        <param name="output_topic" value="/SC/other/state"/>
    </node>

    <node pkg="buggy" exec="engine.py" name="NAND_sim_single" output = "screen" namespace="NAND">
        <param from="$(var config_file)"/>
    </node>

</launch>